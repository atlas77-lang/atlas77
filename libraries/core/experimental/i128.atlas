    operator greater(*const this, other: *const int128) -> int128 {
        // TODO
        return int128::default();
    }
    operator greater_equal(*const this, other: *const int128) -> int128 {
        // TODO
        return int128::default();
    }
    
    // TODO: Find a better name
    fun to_64bits(*const this) -> std::optional<int64> {
        if this->high != 0
        {
            return std::optional<int64>::empty();
        }
        return std::optional<int64>::of(this->low as int64);
    }
    fun to_64bits_unchecked(*const this) -> int64 {
        return this->low as int64;
    }
