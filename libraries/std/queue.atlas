//WARNING: Outdated

import "std/io";
import "std/memory";
import "std/optional";
import "std/vector";
namespace std {
//! A simple FIFO queue data structure.
//! TODO: Add a way to allow for other containers to be used inside of the queue.
public struct queue<T> {
    private:
        items: std::vector<T>;
        //! The index of the head of the queue.
        head: uint64;
        //! The index of the tail of the queue.
        tail: uint64;
        //! The number of items in the queue.
        count: uint64;
        //! Creates a new empty queue.
    public:
        fun new(items: *T, len: uint64) -> std::queue<T> {
            return std::queue<T> {
                .items = std::vector<T>::new(items, len),
                .head = 0u,
                .tail = len,
                .count = len,
            };
        }
        ~queue() {

        }
        fun with_capacity(capacity: uint64) -> std::queue<T> {
            return std::queue<T> {
                .items = std::vector<T>::with_capacity(capacity),
                .head = 0u,
                .tail = 0u,
                .count = 0u,
            };
        }
        //! Adds an item to the back of the queue.
        fun enqueue(*this, item: T) {
            if this->count == this->items.capacity() {
                std::panic("Queue is full");
            }
            
            this->tail = (this->tail + 1u) % this->items.capacity();
            this->count = this->count + 1u;
        }
    }

}